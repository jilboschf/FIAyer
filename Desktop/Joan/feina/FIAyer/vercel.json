{
  "name": "fiayer",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "api/generate.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate.js" },
    { "source": "/api/create-checkout-session", "destination": "/api/create-checkout-session.js" },
    { "source": "/api/bootstrap", "destination": "/api/bootstrap.js" },
    { "source": "/api/me", "destination": "/api/me.js" },
    { "source": "/api/consume-credit", "destination": "/api/consume-credit.js" },
    { "source": "/api/stripe-webhook", "destination": "/api/stripe-webhook.js" }
  ]
}
