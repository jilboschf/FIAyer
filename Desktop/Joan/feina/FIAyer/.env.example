# =========================================================================
# FIAyer — environment variables template
# Copy this file to `.env` (committed ignored) and fill in your values.
# =========================================================================

# ---- Client-side (exposed to the browser via Vite) ----
# Supabase project URL and public anon key.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# OAuth provider toggles. Set to "true" ONLY after you have configured
# the provider inside Supabase → Authentication → Providers.
# When false (or missing), the button is hidden in the login modal so
# users never click a non-working option.
VITE_AUTH_APPLE_ENABLED=false
VITE_AUTH_GOOGLE_ENABLED=false

# ---- Server-side (used only by /api/* serverless functions) ----
# Gemini API key (used by /api/generate).
GEMINI_API_KEY=YOUR_GEMINI_KEY

# Stripe secret key + webhook signing secret.
STRIPE_SECRET_KEY=sk_test_or_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PACK=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Supabase service-role key (used by API routes to update credits).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
